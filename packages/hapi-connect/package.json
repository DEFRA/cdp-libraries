{
  "name": "@defra/hapi-connect",
  "version": "1.0.0",
  "description": "A hapi plugin to mount `connect` based middleware at a route",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "author": "Defra DDTS",
  "license": "OGL-UK-3.0",
  "homepage": "https://github.com/DEFRA/cdp-libraries/tree/main/packages/hapi-connect#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DEFRA/cdp-libraries.git"
  },
  "bugs": {
    "url": "https://github.com/DEFRA/cdp-libraries/issues"
  },
  "keywords": [
    "hapi",
    "defra",
    "tracing"
  ],
  "main": "src/connect.js",
  "scripts": {
    "format": "prettier --write \"**/*.{cjs,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{cjs,js,json,md}\"",
    "git:pre-commit-hook": "npm run format:check && npm run lint",
    "github:release": "npx cdp-github-release hapi-connect",
    "lint": "eslint --cache --cache-strategy content \"**/*.{cjs,js}\"",
    "lint:fix": "npm run lint -- --fix",
    "postinstall": "npm run setup:husky",
    "setup:husky": "node -e \"try { (await import('husky')).default() } catch (e) { if (e.code !== 'ERR_MODULE_NOT_FOUND') throw e }\" --input-type module",
    "test": "vitest run --coverage",
    "test:watch": "vitest --coverage"
  },
  "dependencies": {
    "@hapi/boom": "10.0.1",
    "connect": "3.7.0"
  },
  "devDependencies": {
    "@hapi/hapi": "21.4.4"
  },
  "release-it": {
    "npm": {
      "publish": false
    },
    "github": {
      "release": true,
      "releaseName": "Released hapi-connect ${version}",
      "releaseNotes": "echo ''"
    },
    "git": {
      "commitMessage": "Tagged hapi-connect ${version}",
      "tagName": "hapi-connect-${version}",
      "requireCleanWorkingDir": false,
      "commitArgs": [
        "--no-verify"
      ]
    }
  }
}
